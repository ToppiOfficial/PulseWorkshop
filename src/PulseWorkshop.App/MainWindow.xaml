<Window x:Class="PulseWorkshop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PulseWorkshop.App.ViewModels"
        xmlns:local="clr-namespace:PulseWorkshop.App"
        Title="PulseWorkshop"
        Height="720" Width="1180" MinHeight="560" MinWidth="900"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVis" />
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <local:FirstLetterConverter x:Key="FirstLetter" />
        <local:PathEllipsisConverter x:Key="PathEllipsis" />
    </Window.Resources>

    <Grid Margin="10,2,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- Drag-handle row: the GridSplitter that resizes the top block (editor) vs the terminal
                 drawer. Its own dedicated row directly between them, so PreviousAndNext resizes the
                 editor (Row 0) and the drawer (Row 2) and the splitter reliably grabs the mouse.
                 Collapses to 0 with the drawer (driven in MainWindow.xaml.cs). The Terminal toggle
                 button overlays the editor's bottom-right corner so it stays visible when collapsed. -->
            <RowDefinition x:Name="ConsoleSplitterRowDef" Height="0" />
            <!-- Terminal drawer: collapses to 0 height when the terminal is hidden. -->
            <RowDefinition x:Name="ConsoleRowDef" Height="0" MinHeight="0" />
        </Grid.RowDefinitions>

        <!-- Top-level tabs (the outer container): the Workshop tool, and an About page. The
             Game picker + Connect live inside the Workshop tab - they're Workshop-only; other
             tabs are for tools unrelated to the Steam Workshop connection. -->
        <TabControl Grid.Row="0" x:Name="MainTabs" Background="Transparent" BorderThickness="0" Padding="0"
                    SelectionChanged="MainTabs_SelectionChanged">
          <TabItem Header="Workshop" x:Name="WorkshopTab">
            <DockPanel Margin="0,8,0,0">
            <!-- Connection bar: game picker + connect (Workshop-only). -->
            <Border DockPanel.Dock="Top" Background="{StaticResource HeaderGradientBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="3" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Game" VerticalAlignment="Center" Margin="0,0,8,0"
                           Style="{StaticResource MutedText}" />
                <ComboBox Grid.Column="1" Width="200" ItemsSource="{Binding Games}"
                          SelectedItem="{Binding SelectedGame}" DisplayMemberPath="DisplayName"
                          VerticalAlignment="Center" />

                <!-- Connect / Disconnect occupy the same slot; only one is visible at a time. -->
                <Button Grid.Column="2" Content="Connect" Margin="12,0,0,0" MinWidth="110"
                        Style="{StaticResource AccentButton}" Command="{Binding ConnectCommand}"
                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                <Button Grid.Column="2" Content="Disconnect" Margin="12,0,0,0" MinWidth="110"
                        Style="{StaticResource DisconnectButton}" Command="{Binding DisconnectCommand}"
                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}" />

                <!-- Logged-in Steam user: avatar + persona name + SteamID64, far right. -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasProfile, Converter={StaticResource BoolToVis}}">
                    <Border Width="34" Height="34" CornerRadius="17"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Border.Clip>
                            <EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17" />
                        </Border.Clip>
                        <Grid>
                            <!-- Placeholder initial behind the image (shows until/if avatar loads). -->
                            <TextBlock Text="{Binding PersonaName, Converter={StaticResource FirstLetter}}"
                                       Foreground="{StaticResource MutedTextBrush}" FontSize="15"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <Image Stretch="UniformToFill"
                                   Source="{Binding AvatarUrl, TargetNullValue={x:Null}}"
                                   Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVis}}" />
                        </Grid>
                    </Border>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PersonaName}" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" MaxWidth="180" />
                    </StackPanel>
                </StackPanel>
            </Grid>
            </Border>

            <!-- Resizable top block: main content + action bar share it; the terminal drawer sits below. -->
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Main content: lists on the left, editor on the right -->
            <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Left: separate Published / Drafts / Templates tabs -->
            <Border Grid.Column="0" Background="{StaticResource PanelGradientBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="3" Padding="8">
              <Grid>
                <!-- Tab-strip actions, aligned to the right of the tab headers: Refresh (shown only
                     on the Published tab) + the "+" New item button. -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,0,2,0" Panel.ZIndex="1">
                    <Button Content="Refresh" Padding="8,2" Margin="0,0,6,0" VerticalAlignment="Center"
                            Command="{Binding RefreshPublishedCommand}"
                            Visibility="{Binding IsSelected, ElementName=PublishedTab, Converter={StaticResource BoolToVis}}"
                            ToolTip="Reload the published items from Steam." />
                    <Button Content="+" FontSize="18" FontWeight="Bold" Width="26" Height="26" Padding="0"
                            Command="{Binding NewItemCommand}" ToolTip="New item (creates a draft)" />
                </StackPanel>
                <TabControl x:Name="LeftTabs" Background="Transparent" BorderThickness="0">
                    <TabItem Header="Published" x:Name="PublishedTab">
                        <Grid Margin="4,8,4,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- Search + sort, inline on one row. -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="PublishedSearchBox"
                                         Text="{Binding PublishedSearch, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="SearchBox_KeyDown"
                                         Tag="Search title, tags, description, id..." />
                                <ToggleButton Grid.Column="1" Content=".*" Margin="6,0,0,0" Padding="8,4"
                                              IsChecked="{Binding PublishedRegex}" ToolTip="Regex" />
                                <ComboBox Grid.Column="2" Width="150" Margin="6,0,0,0"
                                          ItemsSource="{Binding PublishedSortOptions}"
                                          SelectedItem="{Binding SelectedPublishedSort}"
                                          ToolTip="Sort the published list." />
                                <ToggleButton Grid.Column="3" Content="Reverse" Margin="6,0,0,0" Padding="8,4"
                                              IsChecked="{Binding PublishedSortReversed}"
                                              ToolTip="Reverse the chosen sort order." />
                            </Grid>

                            <ListBox Grid.Row="1" ItemsSource="{Binding PublishedView}"
                                     BorderThickness="0" Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="PublishedList_SelectionChanged"
                                     x:Name="PublishedList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="56" Height="56" CornerRadius="3"
                                                    Background="{StaticResource PanelAltBrush}">
                                                <Image Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <BitmapImage UriSource="{Binding PreviewUrl}" />
                                                    </Image.Source>
                                                </Image>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding PublishedFileId}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="  |  " Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding Visibility}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="  |  " Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding FileSizeDisplay}" Style="{StaticResource MutedText}" />
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource MutedText}">
                                                    <Run Text="Updated " /><Run Text="{Binding Updated, StringFormat='{}{0:yyyy-MM-dd}', Mode=OneWay}" />
                                                    <Run Text="  -  Published " /><Run Text="{Binding Created, StringFormat='{}{0:yyyy-MM-dd}', Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource LinkButton}"
                                                    VerticalAlignment="Center" Margin="6,0,0,0"
                                                    Click="OpenWorkshopItem_Click"
                                                    ToolTip="Open this item on Steam (falls back to your browser)." />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Drafts" x:Name="DraftsTab">
                        <Grid Margin="4,8,4,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="DraftsSearchBox"
                                         Text="{Binding DraftsSearch, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="SearchBox_KeyDown"
                                         Tag="Search drafts..." />
                                <ToggleButton Grid.Column="1" Content=".*" Margin="6,0,0,0" Padding="8,4"
                                              IsChecked="{Binding DraftsRegex}" ToolTip="Regex" />
                                <ComboBox Grid.Column="2" Width="120" Margin="6,0,0,0"
                                          ItemsSource="{Binding DraftSortOptions}"
                                          SelectedItem="{Binding SelectedDraftSort}"
                                          ToolTip="Sort the drafts list." />
                                <ToggleButton Grid.Column="3" Content="Reverse" Margin="6,0,0,0" Padding="8,4"
                                              IsChecked="{Binding DraftSortReversed}"
                                              ToolTip="Reverse the chosen sort order." />
                            </Grid>
                            <ListBox Grid.Row="1" ItemsSource="{Binding DraftsView}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="DraftsList_SelectionChanged" x:Name="DraftsList">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="3"
                                                Background="{StaticResource PanelAltBrush}">
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding ThumbnailSource}"
                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Modified, StringFormat='Modified {0:g}'}"
                                                       Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource CloneButton}" Click="DraftClone_Click"
                                                    ToolTip="Clone this draft (saves it first, so unsaved edits are copied)." />
                                            <Button Style="{StaticResource TrashButton}" Click="DraftDelete_Click" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Templates" x:Name="TemplatesTab">
                        <Grid Margin="4,8,4,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="TemplatesSearchBox"
                                         Text="{Binding TemplatesSearch, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="SearchBox_KeyDown"
                                         Tag="Search templates..." />
                                <ToggleButton Grid.Column="1" Content=".*" Margin="6,0,0,0" Padding="8,4"
                                              IsChecked="{Binding TemplatesRegex}" ToolTip="Regex" />
                                <ComboBox Grid.Column="2" Width="120" Margin="6,0,0,0"
                                          ItemsSource="{Binding TemplateSortOptions}"
                                          SelectedItem="{Binding SelectedTemplateSort}"
                                          ToolTip="Sort the templates list." />
                                <ToggleButton Grid.Column="3" Content="Reverse" Margin="6,0,0,0" Padding="8,4"
                                              IsChecked="{Binding TemplateSortReversed}"
                                              ToolTip="Reverse the chosen sort order." />
                            </Grid>
                            <ListBox Grid.Row="1" ItemsSource="{Binding TemplatesView}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="TemplatesList_SelectionChanged" x:Name="TemplatesList">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="3"
                                                Background="{StaticResource PanelAltBrush}">
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding ThumbnailSource}"
                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Modified, StringFormat='Edited {0:g}'}"
                                                       Style="{StaticResource MutedText}" Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding DescriptionPreview}" Style="{StaticResource MutedText}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Use" Padding="8,2" Margin="0,0,4,0"
                                                VerticalAlignment="Center" Click="TemplateUse_Click"
                                                ToolTip="Start a new item from this template." />
                                        <Button Grid.Column="3" Style="{StaticResource TrashButton}"
                                                VerticalAlignment="Center" Click="TemplateDelete_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>
              </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Right: editor. The panel's own border turns Steam blue while a draft or template
                 has unsaved changes (see EditorViewModel.HasUnsavedChanges). -->
            <Border Grid.Column="2" Background="{StaticResource PanelGradientBrush}"
                    BorderThickness="2" CornerRadius="3" Padding="15,7,15,15">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Editor.HasUnsavedChanges}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource UnsavedBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock Text="Select an item, draft, or template - or click New item."
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="{Binding Editor, Converter={StaticResource NullToVis}, ConverterParameter=invert}" />

                    <!-- Editor split into Details + Tags tabs (Tags live on their own tab). -->
                    <TabControl x:Name="EditorTabs" DataContext="{Binding Editor}" Background="Transparent" BorderThickness="0" Padding="0"
                                Visibility="{Binding DataContext.Editor, RelativeSource={RelativeSource AncestorType=Border}, Converter={StaticResource NullToVis}}">
                      <TabItem Header="Details">
                        <!-- This tab scrolls so nothing (e.g. Visibility) is cut off on a small window. -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                          <StackPanel>

                        <!-- Title (doubles as the template name in template mode), larger font -->
                        <StackPanel>
                            <TextBlock Text="Title" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="18" Padding="10,8" />
                        </StackPanel>

                        <!-- Description + Change note: side-by-side editors with a drag handle to
                             resize their height (Crowbar-style). The editors live in a fixed-height
                             row that the GridSplitter below grows/shrinks. -->
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="DescRow" Height="220" MinHeight="90" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0">
                                    <TextBlock DockPanel.Dock="Top" Text="Description" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                             FontFamily="Consolas" />
                                </DockPanel>
                                <DockPanel Grid.Column="2">
                                    <TextBlock DockPanel.Dock="Top" Text="{Binding ChangeNoteLabel}"
                                               Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding ChangeNote, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                             FontFamily="Consolas" />
                                </DockPanel>
                            </Grid>
                            <!-- Drag down/up to resize the description + change note height. -->
                            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" ResizeBehavior="PreviousAndCurrent"
                                          ResizeDirection="Rows" Background="Transparent"
                                          Cursor="SizeNS" Margin="0,2,0,0" />
                        </Grid>

                        <!-- Visibility + "manage on Steam" shortcuts (placed above Content/Preview so the
                             preview zone has room to scale). Gallery images/videos and required items have
                             no SDK API for these legacy RemoteStorage games, so we deep-link instead. -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Visibility" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding VisibilityOptions}"
                                          SelectedItem="{Binding Visibility}" Width="180" HorizontalAlignment="Left" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom"
                                        HorizontalAlignment="Right"
                                        Visibility="{Binding IsEditingPublished, Converter={StaticResource BoolToVis}}">
                                <Button Content="Images &amp; Videos" Click="OpenManagePreviews_Click"
                                        Margin="0,0,8,0"
                                        ToolTip="Add/edit gallery images and videos for this item on Steam (no SDK API for these games)." />
                                <Button Content="Required Items" Click="OpenManageRequiredItems_Click"
                                        ToolTip="Manage required items for this item on Steam (no SDK API for these games)." />
                            </StackPanel>
                        </Grid>

                        <!-- Content file + Preview image: drag-drop / click-to-browse zones
                             (also shown in template mode - templates can hold content/preview). -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Content file -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,4">
                                    <Run Text="Content file (" /><Run Text="{Binding ContentFileExtension, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                                <!-- Manual path entry; two-way synced with the drop zone and browse dialog. -->
                                <TextBox Text="{Binding ContentFile, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Type or paste a file path" Margin="0,0,0,6" />
                                <Border x:Name="ContentDrop" Height="250" CornerRadius="3" AllowDrop="True"
                                        Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" Cursor="Hand"
                                        MouseLeftButtonUp="ContentDrop_Click"
                                        DragOver="ContentDrop_DragOver" Drop="ContentDrop_Drop">
                                    <Grid>
                                        <!-- Empty: no new file chosen and no published file to describe. -->
                                        <TextBlock Style="{StaticResource MutedText}" TextAlignment="Center"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" Margin="10"
                                                   Text="Drop or click to choose content file"
                                                   Visibility="{Binding ShowContentPlaceholder, Converter={StaticResource BoolToVis}}" />
                                        <!-- Already-published file (info only; stays unless a new file is chosen). -->
                                        <StackPanel VerticalAlignment="Center" Margin="10"
                                                    Visibility="{Binding ShowPublishedContentInfo, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding PublishedContentInfo}"
                                                       ToolTip="{Binding PublishedContentInfo}"
                                                       TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="Currently published - drop a file to replace"
                                                       Style="{StaticResource MutedText}"
                                                       TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <!-- New file chosen for upload. -->
                                        <StackPanel VerticalAlignment="Center" Margin="10"
                                                    Visibility="{Binding HasContentFile, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding ContentFile, Converter={StaticResource PathEllipsis}}"
                                                       ToolTip="{Binding ContentFile}"
                                                       TextAlignment="Center" />
                                            <TextBlock Text="{Binding ContentFileName, StringFormat='({0})'}"
                                                       Style="{StaticResource MutedText}"
                                                       TextAlignment="Center" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding ContentFileSizeDisplay}" Style="{StaticResource MutedText}"
                                                       TextAlignment="Center" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Preview image -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Preview image" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                                <!-- Manual path entry; two-way synced with the drop zone and browse dialog. -->
                                <TextBox Text="{Binding PreviewImagePath, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Type or paste an image path" Margin="0,0,0,6" />
                                <Border x:Name="PreviewImageDrop" Height="250" CornerRadius="3" AllowDrop="True"
                                        Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" Cursor="Hand"
                                        MouseLeftButtonUp="PreviewDrop_Click"
                                        DragOver="PreviewDrop_DragOver" Drop="PreviewDrop_Drop">
                                    <Grid>
                                        <TextBlock Style="{StaticResource MutedText}" TextAlignment="Center"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" Margin="10"
                                                   Text="Drop or click to choose image"
                                                   Visibility="{Binding HasPreviewDisplay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                        <Image Source="{Binding PreviewDisplaySource}" Stretch="Uniform" Margin="4"
                                               Visibility="{Binding HasPreviewDisplay, Converter={StaticResource BoolToVis}}" />
                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="6"
                                                Background="#AA000000" CornerRadius="3" Padding="6,2"
                                                Visibility="{Binding HasPreviewImage, Converter={StaticResource BoolToVis}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding PreviewImageResolution}" Foreground="White" FontSize="11"
                                                           TextAlignment="Right"
                                                           Visibility="{Binding PreviewImageResolution, Converter={StaticResource StringToVis}}" />
                                                <TextBlock Text="{Binding PreviewImageSizeDisplay}" Foreground="White" FontSize="11"
                                                           TextAlignment="Right" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                          </StackPanel>
                        </ScrollViewer>
                      </TabItem>

                      <TabItem Header="Tags">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                        <!-- Categorized tags (Crowbar-style columns). -->
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Tags" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding TagGroups}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,24,12" MinWidth="140">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />

                                                <!-- Single-select (e.g. GMod "Type") -->
                                                <ComboBox Width="160" HorizontalAlignment="Left"
                                                          ItemsSource="{Binding TypeOptions}"
                                                          SelectedItem="{Binding SelectedType}"
                                                          Visibility="{Binding IsSingle, Converter={StaticResource BoolToVis}}" />

                                                <!-- Multi / limited check-list -->
                                                <StackPanel Visibility="{Binding IsCheckList, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding LimitHint}" Style="{StaticResource MutedText}"
                                                               Margin="0,0,0,4"
                                                               Visibility="{Binding LimitHint, Converter={StaticResource NullToVis}}" />
                                                    <ItemsControl ItemsSource="{Binding Tags}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"
                                                                          IsEnabled="{Binding IsEnabled}"
                                                                          Foreground="{StaticResource TextBrush}" Margin="0,2" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Always-set (fixed) -->
                                                <ItemsControl ItemsSource="{Binding Tags}"
                                                              Visibility="{Binding IsAlwaysSet, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" Margin="0,2" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </DockPanel>
                        </ScrollViewer>
                      </TabItem>

                      <!-- Danger zone: destructive, irreversible actions. Only shown when editing an
                           existing published item (a new item / draft / template has nothing on Steam
                           to delete). -->
                      <TabItem Header="Danger zone"
                               Visibility="{Binding IsEditingPublished, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                          <Border BorderBrush="{StaticResource DangerBrush}" BorderThickness="1"
                                  CornerRadius="3" Padding="16" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Delete this item" FontWeight="SemiBold" FontSize="15"
                                           Foreground="{StaticResource DangerBrush}" Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}"
                                           Text="Permanently removes this item from the Steam Workshop. This cannot be undone - subscribers lose access and the Workshop ID is gone for good." />
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedText}" Margin="0,8,0,0">
                                    <Run Text="Item: " /><Run Text="{Binding Title, Mode=OneWay}" FontWeight="SemiBold" />
                                    <Run Text="  -  ID " /><Run Text="{Binding PublishedFileId, Mode=OneWay}" />
                                </TextBlock>
                                <Button Content="Delete item permanently" Style="{StaticResource DangerButton}"
                                        HorizontalAlignment="Left" Margin="0,14,0,0" Padding="16,8"
                                        Click="DeletePublished_Click"
                                        IsEnabled="{Binding DataContext.CanDeletePublished, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="Permanently delete this item from the Steam Workshop." />
                            </StackPanel>
                          </Border>
                        </ScrollViewer>
                      </TabItem>
                    </TabControl>
                </Grid>
            </Border>
            </Grid>

            <!-- Action bar: sits directly under the editor (terminal drawer is below this block).
                 Indeterminate progress (while busy) on the left, actions on the right. -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="2,0,16,0">
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Terminal toggle: lives in the Workshop action bar so it's always visible and
                         inherently Workshop-only. Toggles the drawer at the window bottom. -->
                    <Button Content="Terminal" Command="{Binding ToggleConsoleCommand}" Margin="0,0,8,0"
                            ToolTip="Show/hide the live Steam host log and upload progress. Shortcut: ~" />
                    <TextBlock Text="{Binding PublishRequirementsHint}" Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding PublishRequirementsHint, Converter={StaticResource StringToVis}}" />
                    <Button Content="Save as template" Click="SaveAsTemplate_Click" Margin="0,0,8,0"
                            ToolTip="Save the current tags / description / visibility as a reusable template."
                            Visibility="{Binding CanSaveAsTemplate, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Revert" Command="{Binding RevertCommand}" Margin="0,0,8,0"
                            ToolTip="Discard this draft and reset to the published item's current state."
                            Visibility="{Binding CanRevert, Converter={StaticResource BoolToVis}}" />
                    <Button Content="{Binding PrimaryActionText}" Style="{StaticResource AccentButton}"
                            Command="{Binding PublishCommand}"
                            Visibility="{Binding ShowItemActions, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
            </Grid>
            </DockPanel>
          </TabItem>

          <!-- Game Setup: standalone config of user-defined games (name, engine, exe/tool paths)
               + shared Steam library folders. Master-detail: a games list on the left, a card-based
               editor on the right. Does not affect the Workshop connection - it's persisted config
               for future tooling. -->
          <TabItem Header="Game Setup">
            <Grid DataContext="{Binding GameSetup}" Margin="0,8,0,0">
              <Grid.Resources>
                <!-- A flat titled section (no own background): the right side is a single gradient
                     panel like the Workshop editor, so sections sit directly on it and just use
                     spacing + a heading to group fields. -->
                <Style x:Key="Card" TargetType="Border">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,20" />
                </Style>
                <Style x:Key="CardTitle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Margin" Value="0,0,0,12" />
                </Style>

                <!-- One reusable row for every tool-path field: label | base dropdown | path |
                     Browse | "missing" warning. Bound to a PathFieldViewModel. -->
                <DataTemplate x:Key="PathFieldRow">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Label}" Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" TextTrimming="CharacterEllipsis" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Choices}"
                                  SelectedItem="{Binding SelectedChoice}"
                                  Margin="0,0,6,0"
                                  ToolTip="Pick a Steam library base, or '(Absolute path)' to type a full path." />
                        <TextBox Grid.Column="2" Text="{Binding PathText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" />
                        <Button Grid.Column="3" Content="Browse..." Margin="6,0,0,0"
                                Command="{Binding BrowseCommand}" />
                        <TextBlock Grid.Column="4" Text="missing" Margin="8,0,0,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource LightDangerBrush}"
                                   ToolTip="The resolved path doesn't exist on disk."
                                   Visibility="{Binding PathMissing, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </DataTemplate>
              </Grid.Resources>

              <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="250" MinWidth="190" />
                  <ColumnDefinition Width="8" />
                  <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <!-- LEFT: games list with add on top, clone/delete at the bottom -->
              <Border Grid.Column="0" Background="{StaticResource PanelGradientBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="3" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="2,2,2,8">
                        <TextBlock Text="Games" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="+" FontSize="18" FontWeight="Bold" Width="26" Height="26" Padding="0"
                                HorizontalAlignment="Right" Command="{Binding AddGameCommand}"
                                ToolTip="Add a new game" />
                    </Grid>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Engine}" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource CloneButton}" Click="GameClone_Click"
                                                ToolTip="Clone this game (as 'Clone of ...')." />
                                        <Button Style="{StaticResource TrashButton}" Click="GameDelete_Click"
                                                ToolTip="Delete this game." />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
              </Border>

              <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" />

              <!-- RIGHT: editor for the selected game - one gradient panel (matching the Workshop
                   editor) with flat titled sections inside. -->
              <Grid Grid.Column="2">
                <TextBlock Text="Select a game on the left, or click + to add one."
                           Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding SelectedGame, Converter={StaticResource NullToVis}, ConverterParameter=invert}" />

                <Border Background="{StaticResource PanelGradientBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="3"
                        Visibility="{Binding SelectedGame, Converter={StaticResource NullToVis}}">
                  <!-- Scrolls when the window is too short. On a taller window the inner grid's
                       MinHeight tracks the scroll viewport, so the Steam library section still
                       stretches to fill the remaining space (no dead gap at the bottom). -->
                  <ScrollViewer x:Name="GameSetupDetailScroll" VerticalScrollBarVisibility="Auto"
                                Padding="16,14,12,14">
                    <Grid MinHeight="{Binding ViewportHeight, ElementName=GameSetupDetailScroll}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- General -->
                    <Border Grid.Row="0" Style="{StaticResource Card}">
                      <StackPanel>
                        <TextBlock Text="General" Style="{StaticResource CardTitle}" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Name" Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Grid.Column="1" Text="{Binding SelectedGame.Name, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Engine" Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding EngineOptions}"
                                      SelectedItem="{Binding SelectedGame.Engine}" />
                        </Grid>
                      </StackPanel>
                    </Border>

                    <!-- Tools -->
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                      <StackPanel>
                        <TextBlock Text="Tools" Style="{StaticResource CardTitle}" />

                        <ContentControl Content="{Binding SelectedGame.GameInfo}"
                                        ContentTemplate="{StaticResource PathFieldRow}" />
                        <ContentControl Content="{Binding SelectedGame.ModelCompiler}"
                                        ContentTemplate="{StaticResource PathFieldRow}" />
                        <ContentControl Content="{Binding SelectedGame.ModelViewer}"
                                        ContentTemplate="{StaticResource PathFieldRow}" />
                        <ContentControl Content="{Binding SelectedGame.PackerTool}"
                                        ContentTemplate="{StaticResource PathFieldRow}" />
                        <ContentControl Content="{Binding SelectedGame.VtfTool}"
                                        ContentTemplate="{StaticResource PathFieldRow}" />

                        <!-- VTF tool launch command: how the Package tool invokes the VTF tool for one
                             image asset. Placeholders are substituted per asset. -->
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="VTF command" Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedGame.VtfToolCommand, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Tag="VTF tool arguments. Placeholders: {input} {output} {outputdir} {outputname}" />
                        </Grid>
                      </StackPanel>
                    </Border>

                    <!-- Steam library folders (stretches to fill the remaining height; bottom margin
                         zeroed so it lines up with the games panel on the left) -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,0">
                      <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Library folders sub-section: Add Library always on top -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                       Text="Steam Library folders" />
                            <Button HorizontalAlignment="Right" Content="Add Library" Padding="10,3"
                                    Command="{Binding AddLibraryCommand}"
                                    ToolTip="Add a Steam library folder (selectable as a base for any path above)." />
                        </Grid>

                        <!-- The table fills the rest of the card; rows scroll inside it. -->
                        <Border Grid.Row="1" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="8">
                          <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Library path" Style="{StaticResource MutedText}"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Browse" Style="{StaticResource MutedText}"
                                           FontWeight="SemiBold" Margin="0,0,38,0" />
                            </Grid>

                            <TextBlock Grid.Row="1" Text="No libraries yet - click 'Add Library' above."
                                       Style="{StaticResource MutedText}" Margin="0,2,0,2"
                                       Visibility="{Binding HasLibraries, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <ItemsControl Grid.Row="2" VerticalAlignment="Top" ItemsSource="{Binding Libraries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding PathText, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="Steam library path (e.g. D:\SteamLibrary)"
                                                     VerticalContentAlignment="Center" />
                                            <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0"
                                                    Command="{Binding BrowseCommand}" />
                                            <Button Grid.Column="2" Style="{StaticResource TrashButton}"
                                                    VerticalAlignment="Center" Margin="2,0,0,0"
                                                    Command="{Binding RemoveCommand}"
                                                    ToolTip="Remove this library." />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </Grid>
                        </Border>
                      </Grid>
                    </Border>
                    </Grid>
                  </ScrollViewer>
                </Border>
              </Grid>
            </Grid>
          </TabItem>

          <!-- Compile: a friendlier take on Crowbar's "Compile MDL". An inner Simple / Advanced
               tab split (Advanced is a placeholder for now). Runs studiomdl on a single .qc using a
               Game Setup entry's tool paths, streaming live output into the bottom Terminal drawer. -->
          <TabItem Header="Compile" x:Name="CompileTab">
            <Grid DataContext="{Binding Compile}" Margin="0,8,0,0">
              <Grid.Resources>
                <!-- The left-hand label of a form row: muted, aligned to its field's text line.
                     Min width keeps the field column's left edge consistent across rows. -->
                <Style x:Key="CompileFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                    <Setter Property="VerticalAlignment" Value="Top" />
                    <Setter Property="MinWidth" Value="60" />
                    <Setter Property="Margin" Value="0,6,12,0" />
                </Style>
              </Grid.Resources>

              <TabControl Background="Transparent" BorderThickness="0" Padding="0">

                <!-- SIMPLE: the working compile form (top) above a fixed, always-visible terminal that
                     shows only this compile's studiomdl output - separate from the Workshop terminal. -->
                <TabItem Header="Simple" x:Name="CompileSimpleTab">
                  <!-- Form on top, terminal below - merged as one panel (no resizable split). The form
                       sizes to its content; the terminal fills the remaining height. -->
                  <Grid Margin="0,8,0,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="100" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                  <Border Grid.Row="0" Background="{StaticResource PanelGradientBrush}" BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1" CornerRadius="3">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,12,14,12">
                      <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Game: full-width dropdown (from the Game Setup roster). -->
                        <TextBlock Grid.Row="0" Text="Game" Style="{StaticResource CompileFieldLabel}" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                                  ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                                  DisplayMemberPath="DisplayName" />

                        <!-- Resolved compiler + gameinfo paths (with "missing" warnings). -->
                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"
                              Visibility="{Binding SelectedGame, Converter={StaticResource NullToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Compiler" Style="{StaticResource MutedText}" Margin="0,0,10,0" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedGame.ModelCompiler.ResolvedPath}"
                                       TextTrimming="CharacterEllipsis" Foreground="{StaticResource MutedTextBrush}"
                                       ToolTip="{Binding SelectedGame.ModelCompiler.ResolvedPath}" />
                            <TextBlock Grid.Column="2" Text="missing" Margin="8,0,0,0"
                                       Foreground="{StaticResource LightDangerBrush}"
                                       ToolTip="The model compiler path doesn't exist - set it in Game Setup."
                                       Visibility="{Binding SelectedGame.ModelCompiler.PathMissing, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Grid.Row="1" Text="GameInfo" Style="{StaticResource MutedText}" Margin="0,3,10,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGame.GameInfo.ResolvedPath}"
                                       TextTrimming="CharacterEllipsis" Margin="0,3,0,0" Foreground="{StaticResource MutedTextBrush}"
                                       ToolTip="{Binding SelectedGame.GameInfo.ResolvedPath}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="missing" Margin="8,3,0,0"
                                       Foreground="{StaticResource LightDangerBrush}"
                                       ToolTip="The gameinfo.txt path doesn't exist - set it in Game Setup."
                                       Visibility="{Binding SelectedGame.GameInfo.PathMissing, Converter={StaticResource BoolToVis}}" />
                        </Grid>

                        <!-- QC file: full-width path + Browse. -->
                        <TextBlock Grid.Row="2" Text="QC file" Style="{StaticResource CompileFieldLabel}" />
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding QcPath, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Type or paste a .qc path" VerticalContentAlignment="Center" />
                            <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0"
                                    Command="{Binding BrowseQcCommand}" />
                        </Grid>

                        <!-- Output: mode dropdown inline with its field (Subfolder name / Work folder path). -->
                        <TextBlock Grid.Row="3" Text="Output" Style="{StaticResource CompileFieldLabel}" />
                        <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Width="220" ItemsSource="{Binding OutputModes}"
                                      SelectedItem="{Binding SelectedOutputMode}" />
                            <!-- One of these two occupies the field cell, depending on the mode. -->
                            <TextBox Grid.Column="1" Margin="6,0,0,0"
                                     Text="{Binding SubfolderName, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Visibility="{Binding ShowSubfolderName, Converter={StaticResource BoolToVis}}"
                                     ToolTip="Folder created beside the .qc to receive the compiled files (preserving the models\... path)." />
                            <TextBox Grid.Column="1" Margin="6,0,0,0"
                                     Text="{Binding WorkFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Absolute path to copy compiled files into" VerticalContentAlignment="Center"
                                     Visibility="{Binding ShowWorkFolder, Converter={StaticResource BoolToVis}}" />
                            <Button Grid.Column="2" Content="Browse..." Margin="6,0,0,0"
                                    Command="{Binding BrowseWorkFolderCommand}"
                                    Visibility="{Binding ShowWorkFolder, Converter={StaticResource BoolToVis}}" />
                        </Grid>

                        <!-- Options: full-width. -->
                        <TextBlock Grid.Row="4" Text="Options" Style="{StaticResource CompileFieldLabel}" />
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,2"
                                 Text="{Binding ExtraOptions, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Extra studiomdl options (e.g. -nox360)" VerticalContentAlignment="Center" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MutedText}" Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Text="-verbose is always added (its output locates the .mdl); a typed -quiet is removed automatically." />

                        <!-- Command preview: full-width, read-only. -->
                        <TextBlock Grid.Row="6" Text="Command" Style="{StaticResource CompileFieldLabel}" />
                        <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,12"
                                 Text="{Binding CommandPreview, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                                 Background="{StaticResource BgBrush}" />

                        <!-- Compile action + status (left) + material options (far right). -->
                        <Grid Grid.Row="7" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Compile" Style="{StaticResource AccentButton}" MinWidth="120"
                                        Padding="16,8" Command="{Binding CompileCommand}" />
                                <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
                                    <ProgressBar Width="200" IsIndeterminate="True" HorizontalAlignment="Left"
                                                 Visibility="{Binding IsCompiling, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Material options: all on one line. Localize + Flat patch are always
                                 visible but disabled until "Get materials on compile" is checked. -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="Get materials on compile"
                                          IsChecked="{Binding GetMaterialOnCompile}"
                                          IsEnabled="{Binding CanGetMaterials}"
                                          Foreground="{StaticResource TextBrush}"
                                          ToolTip="After each successful compile, copy VMT and VTF files to the output folder. Requires Subfolder or Work folder output mode." />
                                <CheckBox Content="Localize" IsChecked="{Binding LocalizeMaterials}"
                                          IsEnabled="{Binding CanConfigureMaterials}"
                                          Margin="14,0,0,0" Foreground="{StaticResource TextBrush}"
                                          ToolTip="Place VTF files beside their VMT instead of preserving the game's materials hierarchy." />
                                <CheckBox Content="Flat patch" IsChecked="{Binding FlatPatchShader}"
                                          IsEnabled="{Binding CanConfigureMaterials}"
                                          Margin="14,0,0,0" Foreground="{StaticResource TextBrush}"
                                          ToolTip="Flatten Patch VMTs into their base shader." />
                            </StackPanel>
                        </Grid>

                      </Grid>
                    </ScrollViewer>
                  </Border>

                  <!-- Embedded Compile terminal: live studiomdl output only. Part of the same panel as
                       the form above (no drag handle) - the form and terminal are merged. -->
                  <Border Grid.Row="1" Margin="0,8,0,0" Background="{StaticResource BgBrush}"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                          CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header strip: title + clear -->
                        <Grid Grid.Row="0" Background="{StaticResource PanelAltBrush}">
                            <TextBlock Text="Terminal" Margin="10,5" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Margin="0,2,6,2">
                                <Button Content="Clear" Padding="10,2" Command="{Binding ClearConsoleCommand}"
                                        ToolTip="Clear the compile output." />
                            </StackPanel>
                        </Grid>

                        <!-- Log text: monospace, read-only but fully selectable, auto-scrolled (code-behind). -->
                        <TextBox Grid.Row="1" x:Name="CompileConsoleBox" Text="{Binding ConsoleText, Mode=OneWay}"
                                 IsReadOnly="True" IsReadOnlyCaretVisible="True" IsUndoEnabled="False"
                                 Background="Transparent" BorderThickness="0" Padding="8,2"
                                 FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextBrush}"
                                 TextWrapping="NoWrap" VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextChanged="OnCompileConsoleTextChanged" />
                    </Grid>
                  </Border>
                  <!-- "Go to file" button: appears after a successful compile; opens Explorer with the .mdl selected. -->
                  <Button Grid.Row="2" Content="Go to file" Command="{Binding GoToMdlCommand}"
                          HorizontalAlignment="Left" Margin="0,6,0,0" Padding="12,6"
                          Visibility="{Binding LastMdlPath, Converter={StaticResource StringToVis}}"
                          ToolTip="{Binding LastMdlPath}" />
                  </Grid>
                </TabItem>

                <!-- ADVANCED: a project-directory workflow. State lives in a .pw_mdlproject file the
                     user picks; it owns its own game selection and an ordered, drag-reorderable list
                     of model entries compiled one at a time. DataContext is the Window's
                     CompileAdvanced VM (the inner TabControl's DataContext is the Simple Compile VM). -->
                <TabItem Header="Advanced" x:Name="CompileAdvancedTab"
                         DataContext="{Binding DataContext.CompileAdvanced, RelativeSource={RelativeSource AncestorType=Window}}">
                  <Grid Margin="0,8,0,4">

                    <!-- No project open: prompt to create or open one. -->
                    <Border Background="{StaticResource PanelGradientBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="3"
                            Visibility="{Binding IsProjectOpen, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                          <TextBlock Text="Advanced compile" FontSize="15" FontWeight="SemiBold"
                                     HorizontalAlignment="Center" />
                          <TextBlock Style="{StaticResource MutedText}" HorizontalAlignment="Center"
                                     Margin="0,6,0,14" TextAlignment="Center" MaxWidth="420" TextWrapping="Wrap"
                                     Text="Create or open a model project (.pw_mdlproject). It stores its own game, entries and options in the folder you choose." />
                          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                              <Button Content="New project..." Style="{StaticResource AccentButton}"
                                      Padding="16,8" Command="{Binding NewProjectCommand}" />
                              <Button Content="Open project..." Margin="8,0,0,0" Padding="16,8"
                                      Command="{Binding OpenProjectCommand}" />
                          </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- Project open: bar + settings (top), the entries list (with its compile-all
                         action bar) fills the middle, then a drag handle + a toggleable, resizable
                         terminal drawer at the bottom (mirrors the Workshop terminal). -->
                    <Grid Visibility="{Binding IsProjectOpen, Converter={StaticResource BoolToVis}}">
                      <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" MinHeight="160" />
                          <RowDefinition x:Name="AdvConsoleSplitterRowDef" Height="0" />
                          <RowDefinition x:Name="AdvConsoleRowDef" Height="0" MinHeight="0" />
                      </Grid.RowDefinitions>

                      <!-- Project bar: name + path, with New / Open / Close. -->
                      <Border Grid.Row="0" Background="{StaticResource HeaderGradientBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                              Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProjectPath, Converter={StaticResource PathEllipsis}, ConverterParameter=70}"
                                           Style="{StaticResource MutedText}" ToolTip="{Binding ProjectPath}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="New" Padding="10,4" Command="{Binding NewProjectCommand}" />
                                <Button Content="Open" Margin="6,0,0,0" Padding="10,4" Command="{Binding OpenProjectCommand}" />
                                <Button Content="Close" Margin="6,0,0,0" Padding="10,4" Command="{Binding CloseProjectCommand}" />
                            </StackPanel>
                        </Grid>
                      </Border>

                      <!-- Project settings: game, global command, material + clean options. -->
                      <Border Grid.Row="1" Margin="0,8,0,0" Background="{StaticResource PanelGradientBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                        <StackPanel Margin="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Game" Style="{StaticResource CompileFieldLabel}" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                                          ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                                          DisplayMemberPath="DisplayName" />

                                <TextBlock Grid.Row="1" Text="Global" Style="{StaticResource CompileFieldLabel}" />
                                <!-- Multi-line, user-resizable: drag the handle below to set its height. -->
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBox x:Name="GlobalCommandBox" Height="50" MinHeight="34"
                                             Text="{Binding GlobalCommand, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                             VerticalContentAlignment="Top"
                                             Tag="studiomdl options shared by every entry. You can use line breaks to organize them - they're flattened to spaces when compiling." />
                                    <Thumb Height="9" Cursor="SizeNS" HorizontalAlignment="Stretch"
                                           DragDelta="GlobalCommandResize_DragDelta" ToolTip="Drag to resize.">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="Transparent" Padding="0,3">
                                                    <Border Height="2" Width="44" CornerRadius="1"
                                                            HorizontalAlignment="Center"
                                                            Background="{StaticResource BorderBrush}" />
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <CheckBox Content="Get materials on compile" IsChecked="{Binding GetMaterialOnCompile}"
                                          Foreground="{StaticResource TextBrush}"
                                          ToolTip="After each successful compile (that moves output out of game), copy VMT and VTF files to the output folder." />
                                <CheckBox Content="Localize" IsChecked="{Binding LocalizeMaterials}"
                                          IsEnabled="{Binding CanConfigureMaterials}" Margin="14,0,0,0"
                                          Foreground="{StaticResource TextBrush}"
                                          ToolTip="Place VTF files beside their VMT instead of preserving the game's materials hierarchy." />
                                <CheckBox Content="Flat patch" IsChecked="{Binding FlatPatchShader}"
                                          IsEnabled="{Binding CanConfigureMaterials}" Margin="14,0,0,0"
                                          Foreground="{StaticResource TextBrush}"
                                          ToolTip="Flatten Patch VMTs into their base shader." />
                                <CheckBox Content="Clean before transfer" IsChecked="{Binding CleanBeforeTransfer}"
                                          Margin="14,0,0,0" Foreground="{StaticResource TextBrush}"
                                          ToolTip="Before a non-in-game compile, delete the previous in-game build so stale files can't leak into the moved output." />
                            </StackPanel>

                            <!-- Optional dedicated materials folder: when checked, the materials/ tree is
                                 written here (always relative to the project root) instead of beside the
                                 compiled models. Absolute or outside-project paths are rejected at copy time. -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                <CheckBox Content="Custom materials folder" IsChecked="{Binding UseCustomMaterialsDir}"
                                          IsEnabled="{Binding CanConfigureMaterials}" VerticalAlignment="Center"
                                          Foreground="{StaticResource TextBrush}"
                                          ToolTip="Put the materials/ folder in a dedicated folder under the project root instead of beside the compiled models." />
                                <TextBox Width="280" Margin="14,0,0,0" VerticalAlignment="Center"
                                         Text="{Binding MaterialsOutputDir, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEditMaterialsDir}"
                                         ToolTip="Folder relative to the project root (e.g. shared/materials_src). Absolute or outside-project paths are not allowed; empty means the project root." />
                                <TextBlock Text="(relative to project root)" Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Model entries: a master-detail layout (entries sidebar + selected-entry
                           editor, like Game Setup / Package) plus the compile-all action bar at the
                           bottom (kept inside this panel so the drag handle below sits directly
                           between the list and the terminal). -->
                      <Border Grid.Row="2" Margin="0,8,0,0" Background="{StaticResource PanelGradientBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                        <Grid Margin="14,10">
                          <Grid.RowDefinitions>
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>

                          <!-- Master-detail: entries sidebar (left) + selected-entry editor (right),
                               like Game Setup. The sidebar shows the entry name + which .qc it uses. -->
                          <Grid Grid.Row="0">
                              <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="230" MinWidth="180" />
                                  <ColumnDefinition Width="8" />
                                  <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>

                              <!-- LEFT: entries list. Add on top; drag the handle to reorder. -->
                              <Border Grid.Column="0" Background="{StaticResource PanelAltBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                      CornerRadius="3" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="2,2,2,8">
                                        <TextBlock Text="Entries" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Content="+" FontSize="18" FontWeight="Bold" Width="26" Height="26" Padding="0"
                                                HorizontalAlignment="Right" Command="{Binding AddEntryCommand}"
                                                ToolTip="Add a QC file to compile" />
                                    </Grid>

                                    <ListBox x:Name="AdvancedEntriesList" Grid.Row="1" ItemsSource="{Binding Entries}"
                                             SelectedItem="{Binding SelectedEntry}"
                                             HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0"
                                             PreviewMouseLeftButtonDown="AdvancedEntries_PreviewMouseLeftButtonDown"
                                             DragOver="AdvancedEntries_DragOver" Drop="AdvancedEntries_Drop" AllowDrop="True"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Drag handle (only this initiates a reorder drag) -->
                                                    <TextBlock Grid.Column="0" Tag="DragHandle" Text="&#x2630;" FontSize="14"
                                                               Margin="0,0,8,0" VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedTextBrush}" Cursor="SizeNS"
                                                               ToolTip="Drag to reorder" />
                                                    <!-- Quick 'Compile all' toggle, editable straight from the list. -->
                                                    <CheckBox Grid.Column="1" IsChecked="{Binding CompileInAll}" VerticalAlignment="Center"
                                                              Margin="0,0,8,0" Foreground="{StaticResource TextBrush}"
                                                              ToolTip="Include this entry when 'Compile all' runs." />
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding QcSummary}" Style="{StaticResource MutedText}"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding ResolvedQcPath}" />
                                                    </StackPanel>
                                                    <!-- Status dot: blue while compiling, red after a failed compile. -->
                                                    <Ellipse Grid.Column="3" Width="8" Height="8" Margin="4,0" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCompiling}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Style="{StaticResource CloneButton}" Command="{Binding CloneCommand}"
                                                                ToolTip="Duplicate this entry." />
                                                        <Button Style="{StaticResource TrashButton}" Command="{Binding RemoveCommand}"
                                                                ToolTip="Remove this entry." />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                              </Border>

                              <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" />

                              <!-- RIGHT: editor for the selected entry. -->
                              <Grid Grid.Column="2">
                                  <TextBlock Text="Select an entry on the left, or click + to add a QC file."
                                             Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Visibility="{Binding HasSelectedEntry, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                                  <ContentControl Content="{Binding SelectedEntry}">
                                    <ContentControl.ContentTemplate>
                                      <DataTemplate>
                                        <DataTemplate.Resources>
                                            <Style x:Key="EntryLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="MinWidth" Value="56" />
                                                <Setter Property="Margin" Value="0,0,8,0" />
                                            </Style>
                                        </DataTemplate.Resources>
                                        <!-- Outline reflects state: blue while compiling, red if the last
                                             compile failed (red persists until the next compile / restart). -->
                                        <Border CornerRadius="3" Padding="12" BorderThickness="2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="{StaticResource DangerColor}"
                                                                                      BlurRadius="9" ShadowDepth="0" Opacity="0.7" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCompiling}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="{StaticResource AccentColor}"
                                                                                      BlurRadius="9" ShadowDepth="0" Opacity="0.85" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                              <StackPanel>
                                                  <CheckBox Content="Include in &quot;Compile all&quot;" Margin="0,0,0,8"
                                                            IsChecked="{Binding CompileInAll}" Foreground="{StaticResource TextBrush}"
                                                            ToolTip="Include this entry when the bottom 'Compile all' button runs." />

                                                  <!-- Name + per-entry actions -->
                                                  <Grid>
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto" />
                                                          <ColumnDefinition Width="*" />
                                                          <ColumnDefinition Width="Auto" />
                                                      </Grid.ColumnDefinitions>
                                                      <TextBlock Text="Name" Style="{StaticResource EntryLabel}" />
                                                      <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="Entry name" VerticalContentAlignment="Center" />
                                                      <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                                          <Button Content="Compile" Style="{StaticResource AccentButton}"
                                                                  MinWidth="84" Padding="10,5" Command="{Binding CompileThisCommand}"
                                                                  ToolTip="Compile only this entry." />
                                                          <Button Content="Go to file" Margin="6,0,0,0" Padding="10,5"
                                                                  Command="{Binding GoToMdlCommand}"
                                                                  Visibility="{Binding LastMdlPath, Converter={StaticResource StringToVis}}"
                                                                  ToolTip="{Binding LastMdlPath}" />
                                                      </StackPanel>
                                                  </Grid>

                                                  <!-- QC + Browse -->
                                                  <Grid Margin="0,8,0,0">
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto" />
                                                          <ColumnDefinition Width="*" />
                                                          <ColumnDefinition Width="Auto" />
                                                      </Grid.ColumnDefinitions>
                                                      <TextBlock Grid.Column="0" Text="QC" Style="{StaticResource EntryLabel}" />
                                                      <TextBox Grid.Column="1" Text="{Binding QcPath, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="Path to .qc (relative to the project, or absolute)"
                                                               VerticalContentAlignment="Center" ToolTip="{Binding ResolvedQcPath}" />
                                                      <Button Grid.Column="2" Content="Browse..." Margin="6,0,0,0"
                                                              Command="{Binding BrowseQcCommand}" />
                                                  </Grid>

                                                  <!-- Output destination: subfolder name + mode -->
                                                  <Grid Margin="0,8,0,0">
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto" />
                                                          <ColumnDefinition Width="*" />
                                                          <ColumnDefinition Width="Auto" />
                                                      </Grid.ColumnDefinitions>
                                                      <TextBlock Grid.Column="0" Text="Output" Style="{StaticResource EntryLabel}" />
                                                      <TextBox Grid.Column="1"
                                                               Text="{Binding SubfolderName, UpdateSourceTrigger=PropertyChanged}"
                                                               IsEnabled="{Binding ShowSubfolder}"
                                                               ToolTip="Subfolder under the project (a nested path like test/bill is allowed). Disabled for 'Compile in game'."
                                                               VerticalContentAlignment="Center" />
                                                      <ComboBox Grid.Column="2" Width="200" Margin="6,0,0,0"
                                                                ItemsSource="{Binding OutputModes}" SelectedItem="{Binding SelectedOutputMode}" />
                                                  </Grid>

                                                  <!-- Per-entry command -->
                                                  <Grid Margin="0,8,0,0">
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto" />
                                                          <ColumnDefinition Width="*" />
                                                      </Grid.ColumnDefinitions>
                                                      <TextBlock Text="Command" Style="{StaticResource EntryLabel}" />
                                                      <TextBox Grid.Column="1" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="Extra studiomdl options for this entry (appended after the global command)"
                                                               VerticalContentAlignment="Center" />
                                                  </Grid>
                                              </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                      </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                  </ContentControl>
                              </Grid>
                          </Grid>

                          <!-- Compile all + status, with the terminal toggle on the right. -->
                          <Grid Grid.Row="1" Margin="0,10,0,0">
                              <StackPanel Orientation="Horizontal">
                                  <Button Content="Compile all" Style="{StaticResource AccentButton}" MinWidth="120"
                                          Padding="16,8" Command="{Binding CompileAllCommand}" />
                                  <Button Content="Cancel" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                                          Padding="14,8" Command="{Binding CancelCommand}"
                                          Visibility="{Binding IsCompiling, Converter={StaticResource BoolToVis}}" />
                                  <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                      <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                                                 TextTrimming="CharacterEllipsis" Margin="0,0,0,4" MaxWidth="420" />
                                      <ProgressBar Width="200" IsIndeterminate="True" HorizontalAlignment="Left"
                                                   Visibility="{Binding IsCompiling, Converter={StaticResource BoolToVis}}" />
                                  </StackPanel>
                              </StackPanel>
                              <ToggleButton Content="Terminal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Padding="12,6" IsChecked="{Binding IsTerminalVisible}"
                                            ToolTip="Show or hide the compile output terminal (toggle with the ~ key)." />
                          </Grid>
                        </Grid>
                      </Border>

                      <!-- Drag handle between the entries panel and the terminal drawer (mirrors the
                           Workshop terminal). Its row + the drawer row are sized in MainWindow.xaml.cs. -->
                      <GridSplitter Grid.Row="3" Height="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                                    Background="Transparent" Cursor="SizeNS" ToolTip="Drag to resize the terminal."
                                    Visibility="{Binding IsTerminalVisible, Converter={StaticResource BoolToVis}}" />

                      <!-- Resizable, toggleable terminal drawer: studiomdl / ModelTool output for this project. -->
                      <Border Grid.Row="4" Margin="0,2,0,0" Background="{StaticResource BgBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                              Visibility="{Binding IsTerminalVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Background="{StaticResource PanelAltBrush}">
                                <TextBlock Text="Terminal" Margin="10,5" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Margin="0,2,6,2">
                                    <Button Content="Clear" Padding="10,2" Command="{Binding ClearConsoleCommand}"
                                            ToolTip="Clear the compile output." />
                                </StackPanel>
                            </Grid>
                            <TextBox Grid.Row="1" x:Name="AdvancedConsoleBox" Text="{Binding ConsoleText, Mode=OneWay}"
                                     IsReadOnly="True" IsReadOnlyCaretVisible="True" IsUndoEnabled="False"
                                     Background="Transparent" BorderThickness="0" Padding="8,2"
                                     FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextBrush}"
                                     TextWrapping="NoWrap" VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextChanged="OnAdvancedConsoleTextChanged" />
                        </Grid>
                      </Border>
                    </Grid>
                  </Grid>
                </TabItem>

              </TabControl>
            </Grid>
          </TabItem>

          <!-- Package: pack a content folder into a .vpk/.gma via the game's packer. An inner
               Simple / Advanced split (Advanced first). Advanced shares the .pw_mdlproject with the
               Compile tab but edits its own entry list; each entry bakes its pre-assets into the
               folder, then runs the packer, streaming output into the bottom Terminal drawer. -->
          <TabItem Header="Package" x:Name="PackageTab">
            <Grid Margin="0,8,0,0">
              <TabControl Background="Transparent" BorderThickness="0" Padding="0">

                <TabItem Header="Simple" x:Name="PackageSimpleTab">
                  <Border Background="{StaticResource PanelGradientBrush}" BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1" CornerRadius="3" Margin="0,8,0,4">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Simple package" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Style="{StaticResource MutedText}" HorizontalAlignment="Center"
                                   Margin="0,6,0,0" TextAlignment="Center" MaxWidth="420" TextWrapping="Wrap"
                                   Text="Coming soon. For now, use the Advanced tab to pack folders into .vpk/.gma." />
                    </StackPanel>
                  </Border>
                </TabItem>

                <TabItem Header="Advanced" x:Name="PackageAdvancedTab" DataContext="{Binding PackageAdvanced}">
                  <Grid Margin="0,8,0,4">

                    <!-- No project open: prompt to create or open one (shared with the Compile tab). -->
                    <Border Background="{StaticResource PanelGradientBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="3"
                            Visibility="{Binding IsProjectOpen, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                          <TextBlock Text="Advanced package" FontSize="15" FontWeight="SemiBold"
                                     HorizontalAlignment="Center" />
                          <TextBlock Style="{StaticResource MutedText}" HorizontalAlignment="Center"
                                     Margin="0,6,0,14" TextAlignment="Center" MaxWidth="440" TextWrapping="Wrap"
                                     Text="Create or open a project (.pw_mdlproject). It's the same project file the Compile tab uses - packaging stores its own entry list inside it." />
                          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                              <Button Content="New project..." Style="{StaticResource AccentButton}"
                                      Padding="16,8" Command="{Binding NewProjectCommand}" />
                              <Button Content="Open project..." Margin="8,0,0,0" Padding="16,8"
                                      Command="{Binding OpenProjectCommand}" />
                          </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- Project open: bar + settings (top), the entries list fills the middle, then a
                         drag handle + toggleable terminal drawer at the bottom. -->
                    <Grid Visibility="{Binding IsProjectOpen, Converter={StaticResource BoolToVis}}">
                      <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" MinHeight="160" />
                          <RowDefinition x:Name="PkgConsoleSplitterRowDef" Height="0" />
                          <RowDefinition x:Name="PkgConsoleRowDef" Height="0" MinHeight="0" />
                      </Grid.RowDefinitions>

                      <!-- Project bar: name + path, with New / Open / Close. -->
                      <Border Grid.Row="0" Background="{StaticResource HeaderGradientBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                              Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProjectPath, Converter={StaticResource PathEllipsis}, ConverterParameter=70}"
                                           Style="{StaticResource MutedText}" ToolTip="{Binding ProjectPath}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="New" Padding="10,4" Command="{Binding NewProjectCommand}" />
                                <Button Content="Open" Margin="6,0,0,0" Padding="10,4" Command="{Binding OpenProjectCommand}" />
                                <Button Content="Close" Margin="6,0,0,0" Padding="10,4" Command="{Binding CloseProjectCommand}" />
                            </StackPanel>
                        </Grid>
                      </Border>

                      <!-- Project settings: game (drives the packer + VTF tool). -->
                      <Border Grid.Row="1" Margin="0,8,0,0" Background="{StaticResource PanelGradientBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                        <Grid Margin="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Game" Style="{StaticResource MutedText}" VerticalAlignment="Center"
                                       MinWidth="60" Margin="0,0,12,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                                      DisplayMemberPath="DisplayName" />
                        </Grid>
                      </Border>

                      <!-- Package entries: header + Add, the reorderable list (fills), and the
                           package-all action bar at the bottom. -->
                      <Border Grid.Row="2" Margin="0,8,0,0" Background="{StaticResource PanelGradientBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                        <Grid Margin="14,10">
                          <Grid.RowDefinitions>
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>

                          <!-- Master-detail: entries sidebar (left) + selected-entry editor (right),
                               like Game Setup. The sidebar shows just folder name + asset count. -->
                          <Grid Grid.Row="0">
                              <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="230" MinWidth="180" />
                                  <ColumnDefinition Width="8" />
                                  <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>

                              <!-- LEFT: entries list. Add on top; drag the handle to reorder. -->
                              <Border Grid.Column="0" Background="{StaticResource PanelAltBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                      CornerRadius="3" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="2,2,2,8">
                                        <TextBlock Text="Entries" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Content="+" FontSize="18" FontWeight="Bold" Width="26" Height="26" Padding="0"
                                                HorizontalAlignment="Right" Command="{Binding AddEntryCommand}"
                                                ToolTip="Add a folder to package" />
                                    </Grid>

                                    <ListBox x:Name="PackageEntriesList" Grid.Row="1" ItemsSource="{Binding Entries}"
                                             SelectedItem="{Binding SelectedEntry}"
                                             HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0"
                                             PreviewMouseLeftButtonDown="PackageEntries_PreviewMouseLeftButtonDown"
                                             DragOver="PackageEntries_DragOver" Drop="PackageEntries_Drop" AllowDrop="True"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Drag handle (only this initiates a reorder drag) -->
                                                    <TextBlock Grid.Column="0" Tag="DragHandle" Text="&#x2630;" FontSize="14"
                                                               Margin="0,0,8,0" VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedTextBrush}" Cursor="SizeNS"
                                                               ToolTip="Drag to reorder" />
                                                    <!-- Quick 'Package all' toggle, editable straight from the list. -->
                                                    <CheckBox Grid.Column="1" IsChecked="{Binding IncludeInAll}" VerticalAlignment="Center"
                                                              Margin="0,0,8,0" Foreground="{StaticResource TextBrush}"
                                                              ToolTip="Include this entry when 'Package all' runs." />
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding AssetSummary}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                    <!-- Status dot: blue while packaging, red after a failed package. -->
                                                    <Ellipse Grid.Column="3" Width="8" Height="8" Margin="4,0" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsPackaging}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Style="{StaticResource CloneButton}" Command="{Binding CloneCommand}"
                                                                ToolTip="Duplicate this entry." />
                                                        <Button Style="{StaticResource TrashButton}" Command="{Binding RemoveCommand}"
                                                                ToolTip="Remove this entry." />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                              </Border>

                              <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" />

                              <!-- RIGHT: editor for the selected entry. -->
                              <Grid Grid.Column="2">
                                  <TextBlock Text="Select an entry on the left, or click + to add a folder."
                                             Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Visibility="{Binding HasSelectedEntry, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                                  <ContentControl Content="{Binding SelectedEntry}">
                                    <ContentControl.ContentTemplate>
                                      <DataTemplate>
                                        <DataTemplate.Resources>
                                            <Style x:Key="PkgEntryLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="MinWidth" Value="56" />
                                                <Setter Property="Margin" Value="0,0,8,0" />
                                            </Style>
                                        </DataTemplate.Resources>
                                        <!-- Outline: blue while packaging, red if the last package failed. -->
                                        <Border CornerRadius="3" Padding="12" BorderThickness="2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="{StaticResource DangerColor}"
                                                                                      BlurRadius="9" ShadowDepth="0" Opacity="0.7" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPackaging}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="{StaticResource AccentColor}"
                                                                                      BlurRadius="9" ShadowDepth="0" Opacity="0.85" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                              <StackPanel>
                                                  <CheckBox Content="Include in &quot;Package all&quot;" Margin="0,0,0,8"
                                                            IsChecked="{Binding IncludeInAll}" Foreground="{StaticResource TextBrush}"
                                                            ToolTip="Include this entry when the bottom 'Package all' button runs." />

                                                  <!-- Name + per-entry actions -->
                                                  <Grid>
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto" />
                                                          <ColumnDefinition Width="*" />
                                                          <ColumnDefinition Width="Auto" />
                                                      </Grid.ColumnDefinitions>
                                                      <TextBlock Text="Name" Style="{StaticResource PkgEntryLabel}" />
                                                      <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="Entry name" VerticalContentAlignment="Center" />
                                                      <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                                          <Button Content="Package" Style="{StaticResource AccentButton}"
                                                                  MinWidth="84" Padding="10,5" Command="{Binding PackageThisCommand}"
                                                                  ToolTip="Package only this entry." />
                                                          <Button Content="Go to file" Margin="6,0,0,0" Padding="10,5"
                                                                  Command="{Binding GoToPackageCommand}"
                                                                  Visibility="{Binding LastPackagePath, Converter={StaticResource StringToVis}}"
                                                                  ToolTip="{Binding LastPackagePath}" />
                                                      </StackPanel>
                                                  </Grid>

                                                  <!-- Folder + Browse -->
                                                  <Grid Margin="0,8,0,0">
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto" />
                                                          <ColumnDefinition Width="*" />
                                                          <ColumnDefinition Width="Auto" />
                                                      </Grid.ColumnDefinitions>
                                                      <TextBlock Grid.Column="0" Text="Folder" Style="{StaticResource PkgEntryLabel}" />
                                                      <TextBox Grid.Column="1" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="Folder to package (relative to the project, or absolute)"
                                                               VerticalContentAlignment="Center" ToolTip="{Binding ResolvedFolderPath}" />
                                                      <Button Grid.Column="2" Content="Browse..." Margin="6,0,0,0"
                                                              Command="{Binding BrowseFolderCommand}" />
                                                  </Grid>

                                                  <!-- Per-entry packer command -->
                                                  <Grid Margin="0,8,0,0">
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto" />
                                                          <ColumnDefinition Width="*" />
                                                      </Grid.ColumnDefinitions>
                                                      <TextBlock Text="Command" Style="{StaticResource PkgEntryLabel}" />
                                                      <TextBox Grid.Column="1" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="Extra packer options for this entry (the .vpk/.gma is written beside the folder)"
                                                               VerticalContentAlignment="Center" />
                                                  </Grid>

                                                  <!-- Pre-assets: transformed + copied into the folder before packing -->
                                                  <Border Margin="0,8,0,0" Background="{StaticResource BgBrush}"
                                                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                          CornerRadius="3" Padding="8">
                                                    <StackPanel>
                                                      <Grid Margin="0,0,0,6">
                                                          <TextBlock Text="Pre-assets" Style="{StaticResource MutedText}"
                                                                     FontWeight="SemiBold" VerticalAlignment="Center" />
                                                          <Button HorizontalAlignment="Right" Content="Add asset" Padding="8,3"
                                                                  Command="{Binding AddAssetCommand}" />
                                                      </Grid>

                                                      <ItemsControl ItemsSource="{Binding Assets}">
                                                        <ItemsControl.ItemTemplate>
                                                          <DataTemplate>
                                                            <Border Background="{StaticResource PanelAltBrush}" CornerRadius="3"
                                                                    Padding="8" Margin="0,0,0,6">
                                                              <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                  <ColumnDefinition Width="Auto" />
                                                                  <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Thumbnail: image when Kind=Image and path loads, blank BgBrush otherwise -->
                                                                <Border Width="96" Height="96" CornerRadius="2" Margin="0,0,8,0"
                                                                        Background="{StaticResource BgBrush}" VerticalAlignment="Top">
                                                                  <Image Source="{Binding ThumbnailSource}" Stretch="UniformToFill" />
                                                                </Border>
                                                                <StackPanel Grid.Column="1">
                                                                <!-- Kind + Input + Browse + clone/remove -->
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="120" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Kind" Style="{StaticResource PkgEntryLabel}" />
                                                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AssetKinds}"
                                                                              SelectedItem="{Binding SelectedKind}" />
                                                                    <TextBlock Grid.Column="2" Text="Input" Style="{StaticResource PkgEntryLabel}"
                                                                               Margin="10,0,8,0" />
                                                                    <TextBox Grid.Column="3" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}"
                                                                             Tag="Source file (relative to the project, or absolute)"
                                                                             VerticalContentAlignment="Center" />
                                                                    <Button Grid.Column="4" Content="Browse..." Margin="6,0,0,0"
                                                                            Command="{Binding BrowseInputCommand}" />
                                                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="2,0,0,0">
                                                                        <Button Style="{StaticResource CloneButton}" Command="{Binding CloneCommand}"
                                                                                ToolTip="Duplicate this asset." />
                                                                        <Button Style="{StaticResource TrashButton}" Command="{Binding RemoveCommand}"
                                                                                ToolTip="Remove this asset." />
                                                                    </StackPanel>
                                                                </Grid>

                                                                <!-- Output dir + filename -->
                                                                <Grid Margin="0,6,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Out dir" Style="{StaticResource PkgEntryLabel}" />
                                                                    <TextBox Grid.Column="1" Text="{Binding OutputDir, UpdateSourceTrigger=PropertyChanged}"
                                                                             Tag="Subfolder inside the package folder (blank = folder root; can't escape it)"
                                                                             VerticalContentAlignment="Center" />
                                                                    <TextBlock Grid.Column="2" Text="File" Style="{StaticResource PkgEntryLabel}"
                                                                               Margin="10,0,8,0" />
                                                                    <TextBox Grid.Column="3" Text="{Binding OutputFileName, UpdateSourceTrigger=PropertyChanged}"
                                                                             Tag="Output file name (the extension sets the format)"
                                                                             VerticalContentAlignment="Center" />
                                                                </Grid>

                                                                <!-- Image: target format -->
                                                                <Grid Margin="0,6,0,0"
                                                                      Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="240" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Convert" Style="{StaticResource PkgEntryLabel}" />
                                                                    <ComboBox Grid.Column="1" ItemsSource="{Binding ImageFormats}"
                                                                              SelectedItem="{Binding SelectedImageFormat}" />
                                                                </Grid>

                                                                <!-- VTF: per-asset command override -->
                                                                <Grid Margin="0,6,0,0"
                                                                      Visibility="{Binding IsVtf, Converter={StaticResource BoolToVis}}">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="VTF cmd" Style="{StaticResource PkgEntryLabel}" />
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding VtfCommand, UpdateSourceTrigger=PropertyChanged}"
                                                                             Tag="Extra VTF arguments for this asset - appended after the Game Setup VTF command. Placeholders: {input} {output} {outputdir} {outputname}"
                                                                             VerticalContentAlignment="Center" />
                                                                </Grid>

                                                                <!-- Text: regex replaces -->
                                                                <StackPanel Margin="0,6,0,0"
                                                                            Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}">
                                                                    <Grid Margin="0,0,0,4">
                                                                        <TextBlock Text="Regex replaces" Style="{StaticResource MutedText}"
                                                                                   VerticalAlignment="Center" />
                                                                        <Button HorizontalAlignment="Right" Content="Add regex" Padding="8,2"
                                                                                Command="{Binding AddRegexCommand}" />
                                                                    </Grid>
                                                                    <ItemsControl ItemsSource="{Binding Regexes}">
                                                                      <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                          <Grid Margin="0,0,0,4">
                                                                              <Grid.ColumnDefinitions>
                                                                                  <ColumnDefinition Width="*" />
                                                                                  <ColumnDefinition Width="*" />
                                                                                  <ColumnDefinition Width="Auto" />
                                                                                  <ColumnDefinition Width="Auto" />
                                                                                  <ColumnDefinition Width="Auto" />
                                                                                  <ColumnDefinition Width="Auto" />
                                                                              </Grid.ColumnDefinitions>
                                                                              <TextBox Grid.Column="0" Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                                                       Tag="Find (regex)" VerticalContentAlignment="Center" Margin="0,0,4,0" />
                                                                              <TextBox Grid.Column="1" Text="{Binding Replacement, UpdateSourceTrigger=PropertyChanged}"
                                                                                       Tag="Replace ($1, ${name}...)" VerticalContentAlignment="Center" Margin="0,0,6,0" />
                                                                              <CheckBox Grid.Column="2" Content="Aa" IsChecked="{Binding IgnoreCase}"
                                                                                        VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"
                                                                                        ToolTip="Ignore case" Margin="0,0,8,0" />
                                                                              <CheckBox Grid.Column="3" Content="ML" IsChecked="{Binding Multiline}"
                                                                                        VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"
                                                                                        ToolTip="Multiline (^ and $ match at line breaks)" Margin="0,0,8,0" />
                                                                              <CheckBox Grid.Column="4" Content="Lit" IsChecked="{Binding IsLiteral}"
                                                                                        VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"
                                                                                        ToolTip="Literal - treat the pattern as plain text, not a regex. Use this for tokens like $CHARA$ that contain special characters." Margin="0,0,4,0" />
                                                                              <Button Grid.Column="5" Style="{StaticResource TrashButton}"
                                                                                      Command="{Binding RemoveCommand}" ToolTip="Remove this replace." />
                                                                          </Grid>
                                                                        </DataTemplate>
                                                                      </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                              </StackPanel>
                                                              </Grid>
                                                            </Border>
                                                          </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                      </ItemsControl>
                                                    </StackPanel>
                                                  </Border>
                                              </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                      </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                  </ContentControl>
                              </Grid>
                          </Grid>

                          <!-- Package all + status, with the terminal toggle on the right. -->
                          <Grid Grid.Row="1" Margin="0,10,0,0">
                              <StackPanel Orientation="Horizontal">
                                  <Button Content="Package all" Style="{StaticResource AccentButton}" MinWidth="120"
                                          Padding="16,8" Command="{Binding PackageAllCommand}" />
                                  <Button Content="Cancel" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                                          Padding="14,8" Command="{Binding CancelCommand}"
                                          Visibility="{Binding IsPackaging, Converter={StaticResource BoolToVis}}" />
                                  <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                      <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                                                 TextTrimming="CharacterEllipsis" Margin="0,0,0,4" MaxWidth="420" />
                                      <ProgressBar Width="200" IsIndeterminate="True" HorizontalAlignment="Left"
                                                   Visibility="{Binding IsPackaging, Converter={StaticResource BoolToVis}}" />
                                  </StackPanel>
                              </StackPanel>
                              <ToggleButton Content="Terminal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Padding="12,6" IsChecked="{Binding IsTerminalVisible}"
                                            ToolTip="Show or hide the package output terminal (toggle with the ~ key)." />
                          </Grid>
                        </Grid>
                      </Border>

                      <!-- Drag handle between the entries panel and the terminal drawer. -->
                      <GridSplitter Grid.Row="3" Height="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                                    Background="Transparent" Cursor="SizeNS" ToolTip="Drag to resize the terminal."
                                    Visibility="{Binding IsTerminalVisible, Converter={StaticResource BoolToVis}}" />

                      <!-- Resizable, toggleable terminal drawer: packer / asset output for this project. -->
                      <Border Grid.Row="4" Margin="0,2,0,0" Background="{StaticResource BgBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                              Visibility="{Binding IsTerminalVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Background="{StaticResource PanelAltBrush}">
                                <TextBlock Text="Terminal" Margin="10,5" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Margin="0,2,6,2">
                                    <Button Content="Clear" Padding="10,2" Command="{Binding ClearConsoleCommand}"
                                            ToolTip="Clear the package output." />
                                </StackPanel>
                            </Grid>
                            <TextBox Grid.Row="1" x:Name="PackageConsoleBox" Text="{Binding ConsoleText, Mode=OneWay}"
                                     IsReadOnly="True" IsReadOnlyCaretVisible="True" IsUndoEnabled="False"
                                     Background="Transparent" BorderThickness="0" Padding="8,2"
                                     FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextBrush}"
                                     TextWrapping="NoWrap" VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextChanged="OnPackageConsoleTextChanged" />
                        </Grid>
                      </Border>
                    </Grid>
                  </Grid>
                </TabItem>

              </TabControl>
            </Grid>
          </TabItem>

          <!-- About: developer + app info, Steam-style profile card. -->
          <TabItem Header="About">
            <ScrollViewer x:Name="AboutScroll" VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
              <Border Background="{StaticResource PanelGradientBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="3" Padding="24" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Margin="0"
                      MinHeight="{Binding ViewportHeight, ElementName=AboutScroll}">
                <StackPanel>
                    <!-- Developer: circular avatar + name + SteamID, like the Steam profile header. -->
                    <StackPanel Orientation="Horizontal">
                        <Border Width="96" Height="96" CornerRadius="48"
                                Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Border.Clip>
                                <EllipseGeometry Center="48,48" RadiusX="48" RadiusY="48" />
                            </Border.Clip>
                            <Grid>
                                <!-- Placeholder initial behind the image (shows until/if the avatar loads). -->
                                <TextBlock Text="{Binding DeveloperName, Converter={StaticResource FirstLetter}}"
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="40"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <Image Stretch="UniformToFill"
                                       Source="{Binding DeveloperAvatarUrl, TargetNullValue={x:Null}}"
                                       Visibility="{Binding DeveloperAvatarUrl, Converter={StaticResource StringToVis}}" />
                            </Grid>
                        </Border>
                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Developer" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding DeveloperName}" FontSize="26" FontWeight="SemiBold"
                                       Margin="0,2,0,0" />
                            <Button Content="GitHub" HorizontalAlignment="Left" Margin="0,10,0,0"
                                    Padding="12,4" Click="OpenDeveloperGitHub_Click"
                                    ToolTip="Open the developer's GitHub." />
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,22,0,18" />

                    <!-- App description + version -->
                    <TextBlock Text="PulseWorkshop" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AppVersionDisplay}" Style="{StaticResource MutedText}"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding AppDescription}" TextWrapping="Wrap"
                               Foreground="{StaticResource TextBrush}" Margin="0,14,0,0" LineHeight="20" />
                    <Button Content="KitsuneResource" HorizontalAlignment="Left" Margin="0,10,0,0"
                            Padding="12,4" Click="OpenKitsuneResource_Click"
                            ToolTip="Open the predecessor project, KitsuneResource, on GitHub." />
                </StackPanel>
              </Border>
            </ScrollViewer>
          </TabItem>
        </TabControl>

        <!-- Drag handle (own dedicated row, directly between the editor and the drawer): resizes the
             editor block (Row 0) vs the terminal drawer (Row 2). Only shown while the terminal is
             visible; its row collapses to 0 with the drawer (driven in MainWindow.xaml.cs). -->
        <GridSplitter Grid.Row="1" Height="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Background="Transparent" Cursor="SizeNS"
                      ToolTip="Drag to resize the terminal."
                      Visibility="{Binding IsConsoleVisible, Converter={StaticResource BoolToVis}}" />

        <!-- Console drawer: live log of the Steam host + upload progress -->
        <Border Grid.Row="2" Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="3" Margin="0,2,0,0"
                Visibility="{Binding IsConsoleVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header strip: title + clear -->
                <Grid Grid.Row="0" Background="{StaticResource PanelAltBrush}">
                    <TextBlock Text="Terminal" Margin="10,5" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,2,6,2">
                        <Button Content="Clear" Padding="10,2" Command="{Binding ClearConsoleCommand}"
                                ToolTip="Clear the console output." />
                    </StackPanel>
                </Grid>

                <!-- Log text: monospace, read-only but fully selectable for copy/paste, auto-scrolled
                     to the newest line (see code-behind). -->
                <TextBox Grid.Row="1" x:Name="ConsoleBox" Text="{Binding ConsoleText, Mode=OneWay}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True" IsUndoEnabled="False"
                         Background="Transparent" BorderThickness="0" Padding="8,2"
                         FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextBrush}"
                         TextWrapping="NoWrap" VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextChanged="OnConsoleTextChanged" />
            </Grid>
        </Border>
    </Grid>
</Window>
