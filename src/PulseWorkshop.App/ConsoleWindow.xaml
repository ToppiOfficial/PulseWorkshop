<Window x:Class="PulseWorkshop.App.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Console"
        Width="900" Height="400" MinWidth="420" MinHeight="200"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <!-- Source-engine console: a colour-coded log fills the window with a command input line pinned
         to the bottom. Steam-flavoured palette (near-white / blue / yellow / red on dark grey). -->
    <Window.Resources>
        <SolidColorBrush x:Key="ConsoleNormalBrush" Color="#E6E6E6" />
        <SolidColorBrush x:Key="ConsoleInfoBrush" Color="#66C0F4" />
        <SolidColorBrush x:Key="ConsoleWarnBrush" Color="#F1C40F" />
        <SolidColorBrush x:Key="ConsoleErrorBrush" Color="#FF6B6B" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Log: coloured Runs (one Paragraph per line, set up in code-behind), read-only but fully
             selectable for copy/paste, auto-scrolled to the newest line unless the user scrolled up. -->
        <RichTextBox x:Name="LogBox" Grid.Row="0" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     IsUndoEnabled="False" Background="{StaticResource BgBrush}"
                     Foreground="{StaticResource ConsoleNormalBrush}" BorderThickness="0" Padding="8,4"
                     FontFamily="Consolas" FontSize="12"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <RichTextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy" Command="Copy" />
                    <MenuItem Header="Select all" Command="SelectAll" />
                    <Separator />
                    <MenuItem Header="Clear" Command="{Binding ClearCommand}" />
                </ContextMenu>
            </RichTextBox.ContextMenu>
        </RichTextBox>

        <!-- Command input line (Source-style). Enter runs the command (handled in code-behind). -->
        <Border Grid.Row="1" Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBox x:Name="InputBox" Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource ConsoleNormalBrush}"
                     CaretBrush="{StaticResource ConsoleInfoBrush}"
                     FontFamily="Consolas" FontSize="12" Padding="8,6"
                     VerticalContentAlignment="Center" KeyDown="InputBox_KeyDown"
                     Tag="Type a command (clear)..." />
        </Border>
    </Grid>
</Window>
